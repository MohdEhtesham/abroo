                <item android:offset="0.55" android:color="#D4AF37" />
                <item android:offset="1.0" android:color="#B5942C" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Inner diamond cutout (royal-blue, signifies "premium / valuable") -->
    <path
        android:fillColor="#1E3A8A"
        android:pathData="M54,40 L62,50 L54,60 L46,50 Z" />

    <!-- Diamond highlight (lighter facet) -->
    <path
        android:fillColor="#3B5BB8"
        android:pathData="M54,40 L62,50 L54,50 Z" />

