        android:pathData="M54,54m-30,0a30,30 0,1 1,60 0a30,30 0,1 1,-60 0Z"
        android:strokeWidth="0">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:centerX="54" android:centerY="44"
                android:gradientRadius="32"
                android:type="radial">
                <item android:offset="0.0" android:color="#33D4AF37" />
                <item android:offset="1.0" android:color="#00D4AF37" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Outer key head (house silhouette) — soft gold shadow ring -->
    <path
        android:fillColor="#0F000000"
        android:pathData="M54,30 L74,46 L74,66 Q74,68 72,68 L36,68 Q34,68 34,66 L34,46 Z" />

    <!-- Key head: house-shaped (pitched roof + body) — solid gold gradient -->
