    <!--
      Aabroo: gold diamond-key icon with a house-shaped head.
      Layout note: Android adaptive icons mask the outer 18dp on each side,
      so the safe-zone is 72x72 centered at (54, 54). All visible content stays inside that.
    -->

    <!-- Soft circular halo behind the key (subtle gold inner glow) -->
